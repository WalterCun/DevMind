# ===========================================
# DEVMIND CORE - Configuración de Entorno
# ===========================================

# --- Base de Datos ---
DB_PASSWORD=devmind123
#DATABASE_URL=postgresql://devmind:devmind123@localhost:5432/devmind
DATABASE_URL=sqlite:///devmind_test.db
DEVMENT_TEST_USE_SQLITE=True

# --- ChromaDB (Memoria Vectorial) ---
CHROMA_URL=http://localhost:8000

# --- Ollama (LLM Local) ---
OLLAMA_URL=http://localhost:11434
#OLLAMA_MODEL=llama3
OLLAMA_MODEL=llama3.2:3b

#OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_MODEL=qwen3-coder:480b-cloud

# --- Lenguajes de programación (separado del modelo LLM) ---
PREFERRED_LANGUAGES=python,javascript

# --- Configuración de App ---
DEVMIND_MODE=native
LOG_LEVEL=INFO
DEVMENT_HOME=$HOME/.devmind

# --- Seguridad ---
SANDBOX_ENABLED=true
AUTO_FIX_ENABLED=false
MAX_CONCURRENT_AGENTS=3

# --- Identidad del Agente (Se sobrescribe con wizard) ---
AGENT_NAME=DevMind
AGENT_PERSONALITY=professional